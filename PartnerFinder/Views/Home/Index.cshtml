@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Dashboard</h1>
    <a class="btn btn-primary" asp-controller="Partners" asp-action="Create">+ Add Partner</a>
</div>

<div class="row g-3 mb-2">
    <div class="col-6 col-md-3">
        <div class="card text-bg-primary h-100"><div class="card-body">
            <div class="fs-2 fw-bold">@Model.TotalPartners</div>
            <div>Total Partners</div>
        </div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-bg-info h-100"><div class="card-body">
            <div class="fs-2 fw-bold">@Model.AiCapableCount</div>
            <div>AI Infrastructure Capable</div>
        </div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-bg-warning h-100"><div class="card-body">
            <div class="fs-2 fw-bold">@Model.PendingReviewCount</div>
            <div>Pending Manual Review</div>
        </div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-bg-secondary h-100"><div class="card-body">
            <div class="fs-2 fw-bold">@Model.MissingContactCount</div>
            <div>Missing Contact Info</div>
        </div></div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header">Recommended Level</div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span><span class="badge bg-success">A</span> 80–100 · Contact first</span>
                    <strong>@Model.LevelA</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span><span class="badge bg-warning text-dark">B</span> 60–79 · Confirm further</span>
                    <strong>@Model.LevelB</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span><span class="badge bg-secondary">C</span> Below 60 · On hold</span>
                    <strong>@Model.LevelC</strong>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-header">Partners by Country</div>
            <div class="card-body p-0">
                @if (!Model.ByCountry.Any())
                {
                    <div class="p-3 text-muted">No partners yet.</div>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <tbody>
                        @foreach (var c in Model.ByCountry)
                        {
                            <tr>
                                <td>@c.Country</td>
                                <td class="text-end pe-3"><strong>@c.Count</strong></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
