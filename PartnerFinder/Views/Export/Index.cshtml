@{
    ViewData["Title"] = "Export";
    var count = ViewBag.Count as int? ?? 0;
}

<h1 class="h3 mb-3">Export</h1>

<p class="text-muted">Download the full partner database (@count record(s)) as CSV or Excel.</p>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">CSV</h5>
                <p class="card-text text-muted">Comma-separated values, opens in Excel, Google Sheets or Numbers.</p>
                <a class="btn btn-primary" asp-action="Csv">Download CSV</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Excel (.xlsx)</h5>
                <p class="card-text text-muted">Native Excel workbook with a frozen header row.</p>
                <a class="btn btn-success" asp-action="Excel">Download Excel</a>
            </div>
        </div>
    </div>
</div>
