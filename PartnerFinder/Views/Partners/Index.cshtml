@model PartnerListViewModel
@{
    ViewData["Title"] = "Partners";

    string LevelBadge(RecommendedLevel l) => l switch
    {
        RecommendedLevel.A => "bg-success",
        RecommendedLevel.B => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Partners <span class="text-muted fs-5">(@Model.Partners.Count)</span></h1>
    <div class="d-flex gap-2">
        @if (ViewBag.AiConfigured == true && (ViewBag.AiPending as int? ?? 0) > 0)
        {
            <form method="post" asp-action="ResearchBatch" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-info"
                        title="Runs AI research on up to 5 partners per click; takes a few minutes.">
                    🤖 AI Research (@ViewBag.AiPending pending)
                </button>
            </form>
        }
        <a class="btn btn-outline-secondary" asp-controller="Export" asp-action="Index">Export</a>
        <a class="btn btn-primary" asp-action="Create">+ Add Partner</a>
    </div>
</div>

<form method="get" asp-action="Index" class="card card-body mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label mb-0">Search</label>
            <input name="query" value="@Model.Query" class="form-control" placeholder="Company, city, services…" />
        </div>
        <div class="col-md-2">
            <label class="form-label mb-0">Country</label>
            <select name="country" class="form-select">
                <option value="">All</option>
                @foreach (var c in Model.Countries)
                {
                    <option value="@c" selected="@(c == Model.Country)">@c</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label mb-0">Service Category</label>
            <select name="serviceCategory" class="form-select">
                <option value="">All</option>
                @foreach (var cat in PartnerFinder.Data.PartnerOptions.ServiceCategories)
                {
                    <option value="@cat" selected="@(cat == Model.ServiceCategory)">@cat</option>
                }
            </select>
        </div>
        <div class="col-md-1">
            <label class="form-label mb-0">Level</label>
            <select name="level" class="form-select">
                <option value="">All</option>
                <option value="A" selected="@(Model.Level == "A")">A</option>
                <option value="B" selected="@(Model.Level == "B")">B</option>
                <option value="C" selected="@(Model.Level == "C")">C</option>
            </select>
        </div>
        <div class="col-md-2">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" name="aiOnly" value="true" id="aiOnly" @(Model.AiOnly ? "checked" : "") />
                <label class="form-check-label" for="aiOnly">AI capable only</label>
            </div>
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </div>
</form>

@if (!Model.Partners.Any())
{
    <div class="alert alert-info">No partners match your filters. <a asp-action="Create">Add one</a>.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Company</th>
                    <th>Location</th>
                    <th>Category</th>
                    <th class="text-center">AI</th>
                    <th class="text-center">Score</th>
                    <th class="text-center">Level</th>
                    <th>Review</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in Model.Partners)
            {
                <tr>
                    <td>
                        <a asp-action="Details" asp-route-id="@p.Id" class="fw-semibold text-decoration-none">@p.CompanyName</a>
                        @if (!p.HasContactInfo)
                        {
                            <span class="badge bg-light text-danger border ms-1" title="Missing contact info">no contact</span>
                        }
                    </td>
                    <td>@(string.Join(", ", new[] { p.City, p.Country }.Where(s => !string.IsNullOrWhiteSpace(s))))</td>
                    <td>@p.ServiceCategory</td>
                    <td class="text-center">@(p.IsAiCapable ? "✅" : "")</td>
                    <td class="text-center">@p.QualificationScore</td>
                    <td class="text-center"><span class="badge @LevelBadge(p.RecommendedLevel)">@p.RecommendedLevel</span></td>
                    <td>@p.ManualReviewStatus</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@p.Id">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@p.Id">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
