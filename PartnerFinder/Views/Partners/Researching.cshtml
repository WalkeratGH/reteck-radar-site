@{
    ViewData["Title"] = "Researching…";
    var company = ViewBag.CompanyName as string ?? "this company";
}

<div id="pf-params"
     data-company="@(ViewBag.CompanyName as string)"
     data-website="@(ViewBag.Website as string)"
     data-source="@(ViewBag.SourceUrl as string)"
     data-run="@Url.Action("FileAndResearchRun", "Partners")"></div>

@Html.AntiForgeryToken()

<div class="text-center py-5" id="pf-working">
    <div class="spinner-border text-primary" style="width:3.5rem;height:3.5rem;" role="status">
        <span class="visually-hidden">Working…</span>
    </div>
    <h3 class="mt-4 mb-2">Filing &amp; researching @company…</h3>
    <p class="text-muted mb-1">Reading the company website and running AI research, then filling the fields for you.</p>
    <p class="text-muted">This usually takes <strong>30–60 seconds</strong>. Please keep this tab open — it will jump to the finished record automatically.</p>
    <div class="progress mt-4 mx-auto" style="max-width:420px;height:8px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:100%"></div>
    </div>
</div>

<div class="alert alert-danger d-none mx-auto" id="pf-fail" style="max-width:560px;"></div>

@section Scripts {
<script>
(function () {
    var p = document.getElementById('pf-params');
    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

    var body = new URLSearchParams();
    body.append('companyName', p.dataset.company || '');
    body.append('website', p.dataset.website || '');
    body.append('sourceUrl', p.dataset.source || '');
    body.append('__RequestVerificationToken', token);

    fetch(p.dataset.run, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body.toString()
    })
    .then(function (r) {
        if (!r.ok) throw new Error('server returned HTTP ' + r.status);
        return r.json();
    })
    .then(function (d) {
        if (d && d.url) { window.location.replace(d.url); return; }
        throw new Error((d && d.error) ? d.error : 'unexpected response');
    })
    .catch(function (e) {
        document.getElementById('pf-working').classList.add('d-none');
        var f = document.getElementById('pf-fail');
        f.classList.remove('d-none');
        f.innerHTML = 'Something went wrong while researching: ' + e.message +
            '.<br>You can close this tab and try again, or file the company manually.';
    });
})();
</script>
}
