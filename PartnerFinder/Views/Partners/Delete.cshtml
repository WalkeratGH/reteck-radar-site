@model Partner
@{
    ViewData["Title"] = "Delete Partner";
}

<h1 class="h3 mb-3 text-danger">Delete Partner</h1>

<div class="alert alert-warning">Are you sure you want to permanently delete this partner?</div>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title mb-1">@Model.CompanyName</h5>
        <div class="text-muted">
            @(string.Join(", ", new[] { Model.City, Model.Country }.Where(s => !string.IsNullOrWhiteSpace(s))))
            @if (!string.IsNullOrWhiteSpace(Model.ServiceCategory)) { <span>· @Model.ServiceCategory</span> }
        </div>
    </div>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
</form>
