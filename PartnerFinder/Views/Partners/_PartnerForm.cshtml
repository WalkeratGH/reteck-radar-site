@model Partner
@{
    var categories = ViewBag.ServiceCategories as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<div class="row g-4">
    <!-- Basic information -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Basic Information</div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="CompanyName" class="form-label"></label>
                    <input asp-for="CompanyName" class="form-control" />
                    <span asp-validation-for="CompanyName" class="text-danger"></span>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Country" class="form-label"></label>
                        <input asp-for="Country" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="City" class="form-label"></label>
                        <input asp-for="City" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="ServiceCategory" class="form-label"></label>
                    <select asp-for="ServiceCategory" asp-items="categories" class="form-select">
                        <option value="">-- select --</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label asp-for="MainServices" class="form-label"></label>
                    <textarea asp-for="MainServices" class="form-control" rows="2"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="Website" class="form-label"></label>
                    <input asp-for="Website" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <!-- Contact -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Contact</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ContactPerson" class="form-label"></label>
                        <input asp-for="ContactPerson" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ContactTitle" class="form-label"></label>
                        <input asp-for="ContactTitle" class="form-control" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="LinkedIn" class="form-label"></label>
                    <input asp-for="LinkedIn" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="SourceUrl" class="form-label"></label>
                    <input asp-for="SourceUrl" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <!-- IT / Data Center capabilities -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">IT / Data Center Capabilities</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="DataCenterExperience" class="form-check-input" /><label asp-for="DataCenterExperience" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="SmartHandsCapability" class="form-check-input" /><label asp-for="SmartHandsCapability" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="ImacCapability" class="form-check-input" /><label asp-for="ImacCapability" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="BreakFixCapability" class="form-check-input" /><label asp-for="BreakFixCapability" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="NetworkSupportCapability" class="form-check-input" /><label asp-for="NetworkSupportCapability" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="ServerSupportCapability" class="form-check-input" /><label asp-for="ServerSupportCapability" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="StorageSupportCapability" class="form-check-input" /><label asp-for="StorageSupportCapability" class="form-check-label"></label></div>
                </div>
                <hr />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="MicrosoftPartnerStatus" class="form-label"></label>
                        <select asp-for="MicrosoftPartnerStatus" asp-items="Html.GetEnumSelectList<PartnerStatus>()" class="form-select"></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="DellPartnerStatus" class="form-label"></label>
                        <select asp-for="DellPartnerStatus" asp-items="Html.GetEnumSelectList<PartnerStatus>()" class="form-select"></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="CiscoPartnerStatus" class="form-label"></label>
                        <select asp-for="CiscoPartnerStatus" asp-items="Html.GetEnumSelectList<PartnerStatus>()" class="form-select"></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="HpePartnerStatus" class="form-label"></label>
                        <select asp-for="HpePartnerStatus" asp-items="Html.GetEnumSelectList<PartnerStatus>()" class="form-select"></select>
                    </div>
                </div>
                <div class="mb-2">
                    <label asp-for="Certifications" class="form-label"></label>
                    <input asp-for="Certifications" class="form-control" placeholder="e.g. ISO 9001, ISO 27001" />
                </div>
            </div>
        </div>
    </div>

    <!-- AI Infrastructure capabilities -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">AI Infrastructure Capabilities</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="AiServerBuildCapability" class="form-check-input" /><label asp-for="AiServerBuildCapability" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="GpuWorkstationBuildCapability" class="form-check-input" /><label asp-for="GpuWorkstationBuildCapability" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="EdgeAiDeploymentCapability" class="form-check-input" /><label asp-for="EdgeAiDeploymentCapability" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="LocalLlmDeploymentCapability" class="form-check-input" /><label asp-for="LocalLlmDeploymentCapability" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="NvidiaGpuExperience" class="form-check-input" /><label asp-for="NvidiaGpuExperience" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="AmdGpuExperience" class="form-check-input" /><label asp-for="AmdGpuExperience" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="NvidiaJetsonExperience" class="form-check-input" /><label asp-for="NvidiaJetsonExperience" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="SmallAiClusterExperience" class="form-check-input" /><label asp-for="SmallAiClusterExperience" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="OnPremAiDeploymentExperience" class="form-check-input" /><label asp-for="OnPremAiDeploymentExperience" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="AiModelInferenceSetup" class="form-check-input" /><label asp-for="AiModelInferenceSetup" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="LinuxDockerKubernetesCapability" class="form-check-input" /><label asp-for="LinuxDockerKubernetesCapability" class="form-check-label"></label></div>
                    <div class="col-md-6 form-check ms-2 mb-2"><input asp-for="CoolingPowerPlanningCapability" class="form-check-input" /><label asp-for="CoolingPowerPlanningCapability" class="form-check-label"></label></div>
                </div>
                <div class="mt-2">
                    <label asp-for="AiInfrastructureSummary" class="form-label"></label>
                    <textarea asp-for="AiInfrastructureSummary" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>
    </div>

    <!-- Evaluation & notes -->
    <div class="col-12">
        <div class="card">
            <div class="card-header fw-semibold">Evaluation &amp; Notes</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="ManualReviewStatus" class="form-label"></label>
                        <select asp-for="ManualReviewStatus" asp-items="Html.GetEnumSelectList<ManualReviewStatus>()" class="form-select"></select>
                    </div>
                    <div class="col-md-8 mb-3">
                        <label asp-for="FollowUpAction" class="form-label"></label>
                        <input asp-for="FollowUpAction" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="AiSummary" class="form-label"></label>
                    <textarea asp-for="AiSummary" class="form-control" rows="2"></textarea>
                </div>
                <div class="mb-1">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="form-text">
                    Qualification Score, AI Infrastructure Score and Recommended Level are calculated automatically when you save.
                </div>
            </div>
        </div>
    </div>
</div>
