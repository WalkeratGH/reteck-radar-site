@model Partner
@{
    ViewData["Title"] = "Add Partner";
}

<h1 class="h3 mb-3">Add Partner</h1>

@if (ViewBag.AutoFillNote != null)
{
    <div class="alert alert-info">@ViewBag.AutoFillNote</div>
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <partial name="_PartnerForm" model="Model" />
    <div class="my-4">
        <button type="submit" class="btn btn-primary">Save Partner</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
