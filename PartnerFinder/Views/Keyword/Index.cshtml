@model PartnerFinder.Services.KeywordRequest
@{
    ViewData["Title"] = "Search Keyword Generator";
    var keywords = ViewBag.Keywords as List<string>;
    var categories = ViewBag.ServiceCategories as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<h1 class="h3 mb-1">Search Keyword Generator</h1>
<p class="text-muted">
    Enter a location and service type to generate ready-to-paste search phrases.
    No paid API is used — copy a phrase, search it in Google/Bing/LinkedIn, then file good matches with
    <a asp-controller="Partners" asp-action="Create">Add Partner</a>.
</p>

<form method="post" asp-action="Index" class="card card-body mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label asp-for="Country" class="form-label">Country</label>
            <input asp-for="Country" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="City" class="form-label">City</label>
            <input asp-for="City" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="ServiceType" class="form-label">Service Type</label>
            <select asp-for="ServiceType" asp-items="categories" class="form-select">
                <option value="">-- any --</option>
            </select>
        </div>
        <div class="col-md-3">
            <div class="form-check mb-2">
                <input asp-for="AiCapabilityRequired" class="form-check-input" />
                <label asp-for="AiCapabilityRequired" class="form-check-label">AI capability required</label>
            </div>
            <button type="submit" class="btn btn-primary w-100">Generate Keywords</button>
        </div>
    </div>
</form>

@if (keywords != null)
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">@keywords.Count keyword(s)</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="copyAll()">Copy all</button>
        </div>
        <ul class="list-group list-group-flush" id="keywordList">
            @foreach (var k in keywords)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span class="kw">@k</span>
                    <span>
                        <a class="btn btn-sm btn-primary" asp-controller="WebSearch" asp-action="Index" asp-route-q="@k">Auto search</a>
                        <a class="btn btn-sm btn-outline-primary" target="_blank" rel="noopener"
                           href="https://www.google.com/search?q=@Uri.EscapeDataString(k)">Google</a>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="copyOne(this)">Copy</button>
                    </span>
                </li>
            }
        </ul>
    </div>
}

<div class="card mt-4">
    <div class="card-header fw-semibold">Official Partner Directories (free, high-quality lists)</div>
    <div class="card-body">
        <p class="text-muted small mb-2">
            Browse a vendor's official partner directory (filter to United States + your solution area),
            copy a company's website, then paste it into <a asp-controller="WebSearch" asp-action="Index">Web Search</a>
            and hit <strong>⚡ File + AI research</strong>. If a directory link has moved, use its "search" fallback.
        </p>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <tbody>
                @foreach (var (label, url, search) in new[]
                {
                    ("Microsoft — AppSource Partner Directory", "https://appsource.microsoft.com/en-us/marketplace/partner-dir", "Microsoft solutions partner directory united states"),
                    ("NVIDIA — Partner Network (GPU / AI builders)", "https://www.nvidia.com/en-us/about-nvidia/partners/", "NVIDIA partner network find a partner united states"),
                    ("Dell Technologies — Find a Partner", "https://www.dell.com/en-us/dt/partner/find-a-partner.htm", "Dell Technologies find a partner locator"),
                    ("Cisco — Partner Locator", "https://www.cisco.com/c/en/us/buy/partner-locator.html", "Cisco partner locator united states"),
                    ("HPE — Find a Partner", "https://findapartner.hpe.com/", "HPE find a partner locator"),
                    ("Supermicro — Where to Buy (AI server builders)", "https://www.supermicro.com/en/wheretobuy", "Supermicro authorized reseller united states"),
                    ("CRN — Solution Provider 500 / MSP 500 lists", "https://www.crn.com/rankings-and-lists", "CRN solution provider 500 list"),
                })
                {
                    <tr>
                        <td>@label</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary" href="@url" target="_blank" rel="noopener">Open</a>
                            <a class="btn btn-sm btn-outline-secondary" target="_blank" rel="noopener"
                               href="https://www.google.com/search?q=@Uri.EscapeDataString(search)">search</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyOne(btn) {
            const text = btn.closest('li').querySelector('.kw').innerText;
            navigator.clipboard.writeText(text).then(() => flash(btn, 'Copied'));
        }
        function copyAll() {
            const items = Array.from(document.querySelectorAll('#keywordList .kw')).map(e => e.innerText);
            navigator.clipboard.writeText(items.join('\n')).then(() => alert('Copied ' + items.length + ' keywords'));
        }
        function flash(btn, msg) {
            const old = btn.innerText; btn.innerText = msg;
            setTimeout(() => btn.innerText = old, 1000);
        }
    </script>
}
