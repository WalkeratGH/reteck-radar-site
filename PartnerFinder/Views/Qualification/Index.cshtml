@model List<Partner>
@{
    ViewData["Title"] = "Qualification Scores";

    string LevelBadge(RecommendedLevel l) => l switch
    {
        RecommendedLevel.A => "bg-success",
        RecommendedLevel.B => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

<h1 class="h3 mb-1">Qualification Scores</h1>
<p class="text-muted">
    100-point model — General IT/SI (70) + AI Infrastructure (30).
    <span class="badge bg-success">A</span> 80–100 ·
    <span class="badge bg-warning text-dark">B</span> 60–79 ·
    <span class="badge bg-secondary">C</span> below 60.
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No partners yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Company</th>
                    <th>Location</th>
                    <th class="text-center">General /70</th>
                    <th class="text-center">AI /30</th>
                    <th class="text-center">Total /100</th>
                    <th class="text-center">Level</th>
                </tr>
            </thead>
            <tbody>
            @{ var rank = 1; }
            @foreach (var p in Model)
            {
                <tr>
                    <td>@(rank++)</td>
                    <td><a asp-controller="Partners" asp-action="Details" asp-route-id="@p.Id" class="text-decoration-none">@p.CompanyName</a></td>
                    <td>@(string.Join(", ", new[] { p.City, p.Country }.Where(s => !string.IsNullOrWhiteSpace(s))))</td>
                    <td class="text-center">@(p.QualificationScore - p.AiInfrastructureScore)</td>
                    <td class="text-center">@p.AiInfrastructureScore</td>
                    <td class="text-center fw-bold">@p.QualificationScore</td>
                    <td class="text-center"><span class="badge @LevelBadge(p.RecommendedLevel)">@p.RecommendedLevel</span></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
